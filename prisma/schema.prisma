generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
}

enum DealResult {
  WON
  LOST
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(MANAGER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedDeals Deal[]          @relation("DealAssignee")
  assignedTasks Task[]          @relation("TaskAssignee")
  notes         Note[]
  documents     Document[]
  stageEvents   DealStageEvent[]
}

model Contact {
  id              String    @id @default(cuid())
  name            String
  company         String?
  phone           String?
  phoneNormalized String?
  email           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  deals     Deal[]
  tasks     Task[]
  notes     Note[]
  documents Document[]

  @@index([phoneNormalized])
  @@index([deletedAt])
}

model Pipeline {
  id     String  @id @default(cuid())
  name   String
  order  Int     @default(0)
  stages Stage[]
  deals  Deal[]
}

model Stage {
  id         String   @id @default(cuid())
  name       String
  order      Int
  color      String   @default("#6b7280")
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])
  deals      Deal[]

  eventsFrom DealStageEvent[] @relation("FromStage")
  eventsTo   DealStageEvent[] @relation("ToStage")
}

model Deal {
  id         String    @id @default(cuid())
  title      String
  amount     Decimal?
  source     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id])

  stageId    String
  stage      Stage    @relation(fields: [stageId], references: [id])

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])

  assigneeId  String?
  assignee    User?    @relation("DealAssignee", fields: [assigneeId], references: [id])

  city        String?
  documentUrl String?
  closedAs    DealResult?
  closedAt    DateTime?

  tasks       Task[]
  notes       Note[]
  documents   Document[]
  stageEvents DealStageEvent[]

  @@index([stageId])
  @@index([assigneeId])
  @@index([contactId])
  @@index([deletedAt])
  @@index([createdAt])
}

model Task {
  id         String    @id @default(cuid())
  title      String
  dueDate    DateTime?
  done       Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  dealId     String?
  deal       Deal?    @relation(fields: [dealId], references: [id])

  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id])

  assigneeId String?
  assignee   User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([assigneeId])
  @@index([dueDate])
  @@index([dealId])
  @@index([done])
}

model Note {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])

  @@index([dealId])
  @@index([contactId])
}

model Document {
  id           String    @id @default(cuid())
  filename     String
  originalName String
  s3Key        String
  s3Url        String
  size         Int
  mimeType     String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  dealId       String?
  deal         Deal?    @relation(fields: [dealId], references: [id])

  contactId    String?
  contact      Contact? @relation(fields: [contactId], references: [id])

  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  @@index([dealId])
  @@index([contactId])
  @@index([deletedAt])
}

model DealStageEvent {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id])

  fromStageId String?
  fromStage   Stage?   @relation("FromStage", fields: [fromStageId], references: [id])

  toStageId   String
  toStage     Stage    @relation("ToStage", fields: [toStageId], references: [id])

  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
}
